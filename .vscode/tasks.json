{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Conda Environment",
            "type": "shell",
            "command": "conda env update --prefix ./env --file environment.yml --prune",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
