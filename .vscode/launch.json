{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: PyPlanet",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "python": "${env:USERPROFILE}\\anaconda3\\envs\\PyPlanet\\python.exe",
            "console": "integratedTerminal",
            "purpose": ["debug-in-terminal"],
            "env": {
                "PATH": "${env:USERPROFILE}\\anaconda3\\envs\\PyPlanet\\Library\\bin;${env:USERPROFILE}\\anaconda3\\envs\\PyPlanet\\Scripts;${env:USERPROFILE}\\anaconda3\\envs\\PyPlanet;${env:PATH}"
            }
        }
    ]
}